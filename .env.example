# Environment Variables for Sensitive Configuration
# Copy this file to .env and fill in with actual values
# .env should NEVER be committed to git

# Database Credentials (required)
TF_VAR_db_username=dbadmin
TF_VAR_db_password=ChangeMeWithSecurePassword123!

# SSM Access (required for 05-ssm-access module)
# List of IP addresses allowed to access EC2 via SSM (JSON array format)
TF_VAR_allowed_source_ips='["70.181.86.188", "70.183.190.80"]'

# RDS Proxy Credentials (optional - only needed if enable_proxy=true in tfvars)
# Leave empty for dev environment
# TF_VAR_rds_proxy_username=rds_proxy_user
# TF_VAR_rds_proxy_password=ChangeMeWithSecurePassword123!

# Cognito Configuration (if needed)
TF_VAR_cognito_client_secret=your-cognito-client-secret

# Application Secrets
TF_VAR_app_secret_key=your-secret-key-here
TF_VAR_api_key=your-api-key-here
